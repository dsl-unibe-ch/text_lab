Bootstrap: docker
From: nvidia/cuda:12.5.0-devel-ubuntu22.04

%environment
    export DEBIAN_FRONTEND=noninteractive
    
    # External model locations (bind-mount at runtime)
    export WHISPER_CACHE=/opt/whisper
    export WHISPERX_CACHE=/opt/whisperx
    export TORCH_HOME=/opt/torch
    export HF_HOME=/opt/huggingface
    export HUGGINGFACE_HUB_CACHE=/opt/huggingface/hub
    export TRANSFORMERS_CACHE=/opt/huggingface/transformers
    export EASYOCR_CACHE=/opt/easyocr
    export PADDLEOCR_CACHE=/opt/paddleocr
    export PADDLEX_HOME=/opt/paddlex
    export OLLAMA_MODELS=/opt/ollama/models
    
    # Certs & Libs
    export SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
    export SSL_CERT_DIR=/etc/ssl/certs
    export REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
    export LD_LIBRARY_PATH=/usr/local/lib/ollama:/opt/conda/lib:$LD_LIBRARY_PATH

    # DEFAULT TO MAIN ENVIRONMENT
    export PATH="/opt/conda/envs/text_lab_main/bin:/opt/conda/bin:$PATH"

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    # 1. Create Shared Model/Cache Directories
    mkdir -p \
        /opt/whisper /opt/ollama/models /opt/whisperx /opt/torch \
        /opt/huggingface /opt/huggingface/hub /opt/huggingface/transformers \
        /opt/easyocr /opt/paddleocr /opt/paddlex
    chmod -R a+rX /opt/whisper /opt/ollama /opt/whisperx /opt/torch /opt/huggingface /opt/easyocr /opt/paddleocr /opt/paddlex

    # 2. Install OS Dependencies
    apt-get update
    echo "ttf-mscorefonts-installer msttcorefonts/accepted-mscorefonts-eula select true" | debconf-set-selections
    apt-get install -y --no-install-recommends \
        software-properties-common ca-certificates curl git build-essential \
        pkg-config ffmpeg libsndfile1 zstd poppler-utils ttf-mscorefonts-installer \
        msttcorefonts fonts-crosextra-caladea fonts-crosextra-carlito gsfonts \
        lcdf-typetools wget bzip2 gnupg libcudnn8 libcudnn8-dev

    # Apptainer (in-container support)
    add-apt-repository -y ppa:apptainer/ppa
    apt-get update
    apt-get install -y apptainer

    # 3. Install Ollama Backend
    curl -fsSL https://ollama.com/install.sh | sh

    # 4. Install Miniconda (The Environment Manager)
    mkdir -p /opt
    wget -qO /tmp/miniconda.sh https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh
    bash /tmp/miniconda.sh -b -p /opt/conda
    rm -f /tmp/miniconda.sh
    export PATH="/opt/conda/bin:$PATH"
    
    # --- NEW: Accept Anaconda ToS for non-interactive builds ---
    conda config --set auto_update_conda false
    conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/main
    conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/r
    # -----------------------------------------------------------

    # ===================================================================
    # ENVIRONMENT 1: TEXT LAB MAIN (Streamlit, Whisper, Paddle, LDA)
    # ===================================================================
    conda create -y -n text_lab_main python=3.11
    export MAIN_PIP="/opt/conda/envs/text_lab_main/bin/python -m pip"
    
    $MAIN_PIP install --upgrade pip setuptools wheel
    
    # PyTorch 2.7.1
    $MAIN_PIP install --no-cache-dir torch==2.7.1 torchvision==0.22.1 torchaudio==2.7.1 --index-url https://download.pytorch.org/whl/cu118

    # Constraints for Whisper/Main
    cat > /tmp/constraints.txt <<'EOF'
torch==2.7.1+cu118
torchvision==0.22.1+cu118
torchaudio==2.7.1+cu118
pyannote-audio>=3.3.2,<4.0.0
huggingface_hub<1.0.0
transformers<5
ctranslate2<4.5.0
EOF

    # Core UI, Data, and App Packages
    $MAIN_PIP install --no-cache-dir --upgrade \
        streamlit requests openai-whisper sentence-transformers \
        scikit-learn umap-learn matplotlib numpy pandas seaborn plotly \
        ipython jupyter polars pyarrow openpyxl datasets soundfile \
        opencv-python-headless scikit-image mcp[cli] openai tabulate \
        tqdm filelock evaluate librosa networkx pyvis \
        pymupdf pymupdf4llm "unstructured[all-docs]" ollama \
        --constraint /tmp/constraints.txt

    # WhisperX & VAD
    $MAIN_PIP install --no-cache-dir --upgrade whisperx==3.4.1 silero_vad --constraint /tmp/constraints.txt

    # PaddleOCR
    $MAIN_PIP install --no-cache-dir --upgrade paddlepaddle-gpu==3.3.0 -i https://www.paddlepaddle.org.cn/packages/stable/cu118/
    $MAIN_PIP install --no-cache-dir --upgrade paddleocr paddlex easyocr

    # *** TOPIC MODELING (LDA) DEPENDENCIES ***
    $MAIN_PIP install --no-cache-dir gensim pyLDAvis spacy nltk wordcloud
    
    # Download Spacy Language Models (For stopword filtering in Topic Modeling)
    /opt/conda/envs/text_lab_main/bin/python -m spacy download en_core_web_sm
    /opt/conda/envs/text_lab_main/bin/python -m spacy download de_core_news_sm
    /opt/conda/envs/text_lab_main/bin/python -m spacy download fr_core_news_sm


    # ===================================================================
    # ENVIRONMENT 2: OLMOCR BACKEND (vLLM, PyTorch 2.4.0, Numpy < 2)
    # ===================================================================
    conda create -y -n olmocr_backend python=3.11
    export OLM_PIP="/opt/conda/envs/olmocr_backend/bin/python -m pip"
    
    $OLM_PIP install --upgrade pip
    
    # Strict pins for vLLM & OlmOCR compatibility
    $OLM_PIP install --no-cache-dir "numpy==1.26.4"
    $OLM_PIP install --no-cache-dir torch==2.4.0+cu118 torchvision==0.19.0+cu118 torchaudio==2.4.0+cu118 --index-url https://download.pytorch.org/whl/cu118
    $OLM_PIP install --no-cache-dir "vllm==0.11.0"
    $OLM_PIP install --no-cache-dir "olmocr[gpu]==0.4.4" --no-deps
    
    # Satisfy olmocr runtime deps safely
    $OLM_PIP install --no-cache-dir \
        "transformers==4.55.2" tokenizers==0.21.4 \
        beaker-py bleach boto3 cached_path ftfy lingua-language-detector \
        markdown2 markdownify orjson "pypdf>=5.2.0" pypdfium2 smart_open zstandard \
        matplotlib pandas seaborn scikit-learn umap-learn opencv-python-headless scikit-image \
        mlflow datasets flask requests Flask-Cors ollama rich

    # ===================================================================
    # FINAL CLEANUP
    # ===================================================================
    conda clean -a -y
    apt-get clean
    rm -rf /var/lib/apt/lists/*
    rm -f /tmp/constraints.txt

%runscript
    exec "$@"